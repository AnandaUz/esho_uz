{
  "name": "esho.uz",
  "version": "0.8.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnandaUz/esho_uz.git"
  },
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build"
    "build:server": "cd server && npm run build"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "typescript": "^6.0.2"
  }
}
